{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Producto",
    "description": "Un esquema de producto para el Ejercicio de AJV",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Identificador único del producto"
        },
        "nombre": {
            "type": "string",
            "description": "El nombre del producto"
        },
        "precio": {
            "type": "number",
            "minimum": 0,
            "description": "Precio del producto en euros, no puede ser negativo"
        },
        "enStock": {
            "type": "boolean",
            "description": "Indica si el producto está disponible en stock o no"
        }
    },
    "required": [
        "id",
        "nombre",
        "precio"
    ],
    "additionalProperties": false
}